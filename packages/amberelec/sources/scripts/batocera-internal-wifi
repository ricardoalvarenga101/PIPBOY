#!/bin/bash

ACTION=$1
shift

do_help() {
    echo "${0}: Enables or disables internal wifi and reloads connman so if external dongle is connected it will immediately connect" >&2
    echo ""
    echo "Examples:"
    echo "${0} enable" >&2
    echo "${0} disable" >&2
}

do_enable() {
  if [ "$USE_RFKILL" == "1" ]; then
    # Desbloqueia o chip interno e reinicia o connman para detectar interfaces
    _rfkill_unblock
    _refresh_connman
  else
    _gpio_power 1
    _refresh_connman
  fi
}
do_disable() {
  if [ "$USE_RFKILL" == "1" ]; then
    # Para o connman primeiro, depois bloqueia — evita que ele reabra o chip
    connmanctl disable wifi
    sleep 1
    _rfkill_block
  else
    connmanctl disable wifi
    _gpio_power 0
  fi
}
_rfkill_unblock() {
  # Desbloqueia apenas o phy0 (WiFi interno SDIO), nunca o adaptador OTG USB
  local id
  id=$(rfkill list | awk -F: '/phy0/{print $1}' | tr -d ' ' | head -1)
  if [ -n "$id" ]; then
    rfkill unblock "$id"
  else
    rfkill unblock wifi
  fi
}
_rfkill_block() {
  # Bloqueia apenas o phy0 (WiFi interno SDIO), nunca o adaptador OTG USB
  local id
  id=$(rfkill list | awk -F: '/phy0/{print $1}' | tr -d ' ' | head -1)
  if [ -n "$id" ]; then
    rfkill block "$id"
  else
    rfkill block wifi
  fi
}
_gpio_power() {
  echo "$1" > "$GPIO_WIFI_DEVICE"
}

_refresh_connman() {
    connmanctl disable wifi
    sleep 1
    local counter=0
    while [ "$counter" -lt 5 ]; do
        counter=$((counter + 1))
        connmanctl enable wifi
        wifi_scan=$(connmanctl scan wifi 2>&1)
        echo "wifi scan: $wifi_scan"
        if [[ "$wifi_scan" =~ Error ]]; then
          echo "error retry"
          sleep 1
        else
          break
        fi
    done
}


DEVICE_MODEL=$(tr -d '\0' < /sys/firmware/devicetree/base/model)
USE_RFKILL=0
if [ "$DEVICE_MODEL" == "Anbernic RG552" ]; then
  GPIO_WIFI_DEVICE="/sys/class/gpio/gpio113/value"
elif [ "$DEVICE_MODEL" == "Anbernic RG351P" ]; then
  GPIO_WIFI_DEVICE="/sys/class/gpio/gpio110/value"
elif [ "$DEVICE_MODEL" == "Anbernic RG351V" ]; then
  GPIO_WIFI_DEVICE="/sys/class/gpio/gpio5/value"
else
  # R50S, RG351MP e outros: WiFi sem GPIO dedicado — usar rfkill (soft block)
  USE_RFKILL=1
fi

case "${ACTION}" in
    "enable")
        do_enable
        ;;
    "disable")
        do_disable
        ;;
    "disable-no-refresh")
        if [ "$USE_RFKILL" == "1" ]; then
          _rfkill_block
        else
          _gpio_power 0
        fi
        ;;
    *)
        do_help "${0}"
esac