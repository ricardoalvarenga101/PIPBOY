# Configuração padrão do Moonlight Embedded para PipBoy
#
# Para editar: ssh root@<IP>, senha: pipboy
# Edite: /storage/.config/moonlight-embedded/moonlight.conf
#
# Resolução: 854x480 (nativa para RG351MP e displaylinks)
#
# FPS: 30 (mais estável em Wi-Fi 2.4GHz)
#     60 (recomendado com 5GHz)
#
# BitRate: 2500 kbps (padrão - baixa latência) ou 5000+ kbps (maior qualidade)
#
# Exemplo de entrada de configuração:
#
#   resolution=854x480
#   fps=30
#   bitrate=2500
#   codec=hevc
#   app=Desktop
#   host=192.168.100.46
#

# Resoluções suportadas - Presets:
# 640x360 (NHDTV) - padrão
# 800x600 (SVGA)
# 1024x576 (HDTV)
# 1280x720 (HD) - recomendado para RG351MP
# 1366x768 (HD+)
# 1920x1080 (Full HD)
# 854x480 - resolução customizada
# E qualquer outro WIDTHxHEIGHT no formato XXXxYYY

# Codecs suportados:
# auto, h264, hevc (H.265)
